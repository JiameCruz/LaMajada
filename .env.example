# Supabase (requeridas en Vercel → Settings → Environment Variables)
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Usa la "anon legacy" (JWT que empieza con eyJ...) desde Supabase → Settings → API.
# NO uses la publishable key (sb_publishable_...) — falla lecturas públicas en producción.
PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-legacy-key
