---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/admin/auth';
import { uploadImage } from '../../../lib/admin/upload';

const supabase = Astro.locals.supabase;
const session = await requireAdmin(supabase);

if (!session) {
  return Astro.redirect('/admin/login');
}

const { admin } = session;
const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/menu');
}

const { data: item, error } = await supabase.from('menu_items').select('*').eq('id', id).maybeSingle();

if (error || !item) {
  return Astro.redirect('/admin/menu');
}

let formError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const nombre = String(formData.get('nombre') ?? '').trim();
  const descripcion = String(formData.get('descripcion') ?? '').trim();
  const precioRaw = String(formData.get('precio') ?? '').trim();
  const categoria = String(formData.get('categoria') ?? '');
  const alt_text = String(formData.get('alt_text') ?? '').trim();
  const orden = Number(formData.get('orden') ?? 0);
  const activo = formData.get('activo') === 'on';
  const imagenUrl = String(formData.get('imagen_url') ?? '').trim();
  const imagenFile = formData.get('imagen_file');

  const precio = Number(precioRaw);

  if (!nombre || !descripcion || !precioRaw || Number.isNaN(precio) || precio < 0) {
    formError = 'Completa nombre, descripción y un precio válido.';
  } else if (categoria !== 'platos' && categoria !== 'bebidas') {
    formError = 'Selecciona una categoría válida.';
  } else {
    let imagen = imagenUrl || item.imagen;

    if (imagenFile instanceof File && imagenFile.size > 0) {
      const { url, error: uploadError } = await uploadImage(supabase, 'menu-images', imagenFile);
      if (uploadError || !url) {
        formError = uploadError ?? 'No se pudo subir la imagen.';
      } else {
        imagen = url;
      }
    }

    if (!formError) {
      const { error: updateError } = await supabase
        .from('menu_items')
        .update({
          nombre,
          descripcion,
          precio,
          categoria,
          alt_text: alt_text || nombre,
          orden: Number.isFinite(orden) ? orden : 0,
          activo,
          imagen,
        })
        .eq('id', id);

      if (updateError) {
        formError = 'No se pudo actualizar el ítem.';
        console.error(updateError);
      } else {
        return Astro.redirect('/admin/menu?success=updated');
      }
    }
  }
}
---

<AdminLayout
  title="Editar ítem"
  subtitle={item.nombre}
  currentNav="menu"
  adminName={admin.nombre}
  adminEmail={admin.email}
>
  {
    formError && (
      <div class="admin-alert admin-alert--error" role="alert">
        {formError}
      </div>
    )
  }

  <form class="admin-form" method="POST" enctype="multipart/form-data">
    <div class="admin-field">
      <label for="nombre">Nombre</label>
      <input id="nombre" name="nombre" type="text" value={item.nombre} required />
    </div>

    <div class="admin-field">
      <label for="descripcion">Descripción</label>
      <textarea id="descripcion" name="descripcion" required>{item.descripcion}</textarea>
    </div>

    <div class="admin-field">
      <label for="precio">Precio (MXN)</label>
      <input
        id="precio"
        name="precio"
        type="number"
        min="0"
        step="0.01"
        value={Number(item.precio)}
        required
      />
    </div>

    <div class="admin-field">
      <label for="categoria">Categoría</label>
      <select id="categoria" name="categoria" required>
        <option value="platos" selected={item.categoria === 'platos'}>Platos</option>
        <option value="bebidas" selected={item.categoria === 'bebidas'}>Bebidas</option>
      </select>
    </div>

    <div class="admin-field">
      <label for="orden">Orden</label>
      <input id="orden" name="orden" type="number" min="0" value={item.orden} />
    </div>

    <div class="admin-field">
      <label for="alt_text">Texto alternativo</label>
      <input id="alt_text" name="alt_text" type="text" value={item.alt_text ?? ''} />
    </div>

    <label class="admin-checkbox">
      <input type="checkbox" name="activo" checked={item.activo} />
      Visible en el sitio
    </label>

    <div class="admin-field">
      <label>Imagen actual</label>
      <img class="admin-table-thumb" src={item.imagen} alt="" width="80" height="80" />
    </div>

    <div class="admin-field">
      <label for="imagen_file">Nueva imagen (archivo)</label>
      <input id="imagen_file" name="imagen_file" type="file" accept="image/*" />
    </div>

    <div class="admin-field">
      <label for="imagen_url">URL de imagen</label>
      <input id="imagen_url" name="imagen_url" type="text" value={item.imagen} />
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Guardar cambios</button>
      <a href="/admin/menu" class="admin-btn admin-btn--ghost">Cancelar</a>
    </div>
  </form>
</AdminLayout>
