---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/admin/auth';
import { uploadImage } from '../../../lib/admin/upload';

const supabase = Astro.locals.supabase;
const session = await requireAdmin(supabase);

if (!session) {
  return Astro.redirect('/admin/login');
}

const { admin } = session;
let formError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const nombre = String(formData.get('nombre') ?? '').trim();
  const descripcion = String(formData.get('descripcion') ?? '').trim();
  const precioRaw = String(formData.get('precio') ?? '').trim();
  const categoria = String(formData.get('categoria') ?? '');
  const alt_text = String(formData.get('alt_text') ?? '').trim();
  const orden = Number(formData.get('orden') ?? 0);
  const imagenUrl = String(formData.get('imagen_url') ?? '').trim();
  const imagenFile = formData.get('imagen_file');

  const precio = Number(precioRaw);

  if (!nombre || !descripcion || !precioRaw || Number.isNaN(precio) || precio < 0) {
    formError = 'Completa nombre, descripción y un precio válido.';
  } else if (categoria !== 'platos' && categoria !== 'bebidas') {
    formError = 'Selecciona una categoría válida.';
  } else {
    let imagen = imagenUrl;

    if (imagenFile instanceof File && imagenFile.size > 0) {
      const { url, error } = await uploadImage(supabase, 'menu-images', imagenFile);
      if (error || !url) {
        formError = error ?? 'No se pudo subir la imagen.';
      } else {
        imagen = url;
      }
    }

    if (!formError) {
      if (!imagen) {
        formError = 'Agrega una imagen (archivo o URL).';
      } else {
        const { error } = await supabase.from('menu_items').insert({
          nombre,
          descripcion,
          precio,
          categoria,
          alt_text: alt_text || nombre,
          orden: Number.isFinite(orden) ? orden : 0,
          imagen,
        });

        if (error) {
          formError = 'No se pudo guardar el ítem.';
          console.error(error);
        } else {
          return Astro.redirect('/admin/menu?success=created');
        }
      }
    }
  }
}
---

<AdminLayout
  title="Nuevo ítem"
  subtitle="Agrega un platillo o bebida a la carta."
  currentNav="menu"
  adminName={admin.nombre}
  adminEmail={admin.email}
>
  {
    formError && (
      <div class="admin-alert admin-alert--error" role="alert">
        {formError}
      </div>
    )
  }

  <form class="admin-form" method="POST" enctype="multipart/form-data">
    <div class="admin-field">
      <label for="nombre">Nombre</label>
      <input id="nombre" name="nombre" type="text" required />
    </div>

    <div class="admin-field">
      <label for="descripcion">Descripción</label>
      <textarea id="descripcion" name="descripcion" required></textarea>
    </div>

    <div class="admin-field">
      <label for="precio">Precio (MXN)</label>
      <input id="precio" name="precio" type="number" min="0" step="0.01" required />
    </div>

    <div class="admin-field">
      <label for="categoria">Categoría</label>
      <select id="categoria" name="categoria" required>
        <option value="platos">Platos</option>
        <option value="bebidas">Bebidas</option>
      </select>
    </div>

    <div class="admin-field">
      <label for="orden">Orden</label>
      <input id="orden" name="orden" type="number" min="0" value="0" />
      <p class="admin-field-hint">Menor número aparece primero dentro de su categoría.</p>
    </div>

    <div class="admin-field">
      <label for="alt_text">Texto alternativo (accesibilidad)</label>
      <input id="alt_text" name="alt_text" type="text" />
      <p class="admin-field-hint">Si lo dejas vacío, se usará el nombre.</p>
    </div>

    <div class="admin-field">
      <label for="imagen_file">Imagen (archivo)</label>
      <input id="imagen_file" name="imagen_file" type="file" accept="image/*" />
    </div>

    <div class="admin-field">
      <label for="imagen_url">O URL de imagen</label>
      <input id="imagen_url" name="imagen_url" type="text" placeholder="/Image/ejemplo.jpg" />
      <p class="admin-field-hint">Usa una ruta local (/Image/...) o URL de Supabase Storage.</p>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Guardar</button>
      <a href="/admin/menu" class="admin-btn admin-btn--ghost">Cancelar</a>
    </div>
  </form>
</AdminLayout>
