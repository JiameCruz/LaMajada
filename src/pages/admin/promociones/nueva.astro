---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/admin/auth';
import { uploadImage } from '../../../lib/admin/upload';

const supabase = Astro.locals.supabase;
const session = await requireAdmin(supabase);

if (!session) {
  return Astro.redirect('/admin/login');
}

const { admin } = session;
let formError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const descripcion = String(formData.get('descripcion') ?? '').trim();
  const alt_text = String(formData.get('alt_text') ?? '').trim();
  const orden = Number(formData.get('orden') ?? 0);
  const imagenUrl = String(formData.get('imagen_url') ?? '').trim();
  const imagenFile = formData.get('imagen_file');

  if (!descripcion) {
    formError = 'La descripción es obligatoria.';
  } else {
    let imagen = imagenUrl;

    if (imagenFile instanceof File && imagenFile.size > 0) {
      const { url, error } = await uploadImage(supabase, 'promo-images', imagenFile);
      if (error || !url) {
        formError = error ?? 'No se pudo subir la imagen.';
      } else {
        imagen = url;
      }
    }

    if (!formError) {
      if (!imagen) {
        formError = 'Agrega una imagen (archivo o URL).';
      } else {
        const { error } = await supabase.from('promociones').insert({
          descripcion,
          alt_text: alt_text || 'Promoción de La Majada',
          orden: Number.isFinite(orden) ? orden : 0,
          imagen,
        });

        if (error) {
          formError = 'No se pudo guardar la promoción.';
          console.error(error);
        } else {
          return Astro.redirect('/admin/promociones?success=created');
        }
      }
    }
  }
}
---

<AdminLayout
  title="Nueva promoción"
  subtitle="Agrega una oferta visible en el sitio."
  currentNav="promociones"
  adminName={admin.nombre}
  adminEmail={admin.email}
>
  {
    formError && (
      <div class="admin-alert admin-alert--error" role="alert">
        {formError}
      </div>
    )
  }

  <form class="admin-form" method="POST" enctype="multipart/form-data">
    <div class="admin-field">
      <label for="descripcion">Descripción</label>
      <textarea id="descripcion" name="descripcion" required></textarea>
      <p class="admin-field-hint">
        Incluye horario, título y detalle — es el texto que verán los visitantes.
      </p>
    </div>

    <div class="admin-field">
      <label for="orden">Orden</label>
      <input id="orden" name="orden" type="number" min="0" value="0" />
    </div>

    <div class="admin-field">
      <label for="alt_text">Texto alternativo</label>
      <input id="alt_text" name="alt_text" type="text" />
    </div>

    <div class="admin-field">
      <label for="imagen_file">Imagen (archivo)</label>
      <input id="imagen_file" name="imagen_file" type="file" accept="image/*" />
    </div>

    <div class="admin-field">
      <label for="imagen_url">O URL de imagen</label>
      <input id="imagen_url" name="imagen_url" type="text" placeholder="/Image/ejemplo.jpg" />
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Guardar</button>
      <a href="/admin/promociones" class="admin-btn admin-btn--ghost">Cancelar</a>
    </div>
  </form>
</AdminLayout>
