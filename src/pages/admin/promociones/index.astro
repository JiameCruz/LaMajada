---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/admin/auth';

const supabase = Astro.locals.supabase;
const session = await requireAdmin(supabase);

if (!session) {
  return Astro.redirect('/admin/login');
}

const { admin } = session;
const success = Astro.url.searchParams.get('success');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  const id = String(formData.get('id') ?? '');

  if (action === 'toggle' && id) {
    const activo = formData.get('activo') === 'true';
    await supabase.from('promociones').update({ activo: !activo }).eq('id', id);
    return Astro.redirect('/admin/promociones?success=updated');
  }

  if (action === 'delete' && id) {
    await supabase.from('promociones').delete().eq('id', id);
    return Astro.redirect('/admin/promociones?success=deleted');
  }
}

const { data: promociones } = await supabase
  .from('promociones')
  .select('*')
  .order('orden', { ascending: true });
---

<AdminLayout
  title="Promociones"
  subtitle="Ofertas visibles en la sección de promociones del sitio."
  currentNav="promociones"
  adminName={admin.nombre}
  adminEmail={admin.email}
>
  <a slot="actions" href="/admin/promociones/nueva" class="admin-btn admin-btn--primary">
    Nueva promoción
  </a>

  {
    success && (
      <div class="admin-alert admin-alert--success" role="status">
        {success === 'created' && 'Promoción creada correctamente.'}
        {success === 'updated' && 'Promoción actualizada.'}
        {success === 'deleted' && 'Promoción eliminada.'}
      </div>
    )
  }

  {
    !promociones?.length ? (
      <div class="admin-empty">
        <p>Aún no hay promociones publicadas.</p>
        <a href="/admin/promociones/nueva" class="admin-btn admin-btn--primary">
          Crear la primera
        </a>
      </div>
    ) : (
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Imagen</th>
              <th>Descripción</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {promociones.map((promo) => (
              <tr>
                <td>
                  <img class="admin-table-thumb" src={promo.imagen} alt="" width="48" height="48" />
                </td>
                <td>{promo.descripcion.slice(0, 80)}{promo.descripcion.length > 80 ? '…' : ''}</td>
                <td>
                  <span
                    class={`admin-badge ${promo.activo ? 'admin-badge--active' : 'admin-badge--inactive'}`}
                  >
                    {promo.activo ? 'Activa' : 'Oculta'}
                  </span>
                </td>
                <td>
                  <div class="admin-actions">
                    <a
                      href={`/admin/promociones/${promo.id}`}
                      class="admin-btn admin-btn--ghost admin-btn--small"
                    >
                      Editar
                    </a>
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="action" value="toggle" />
                      <input type="hidden" name="id" value={promo.id} />
                      <input type="hidden" name="activo" value={String(promo.activo)} />
                      <button type="submit" class="admin-btn admin-btn--ghost admin-btn--small">
                        {promo.activo ? 'Ocultar' : 'Mostrar'}
                      </button>
                    </form>
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={promo.id} />
                      <button
                        type="submit"
                        class="admin-btn admin-btn--danger admin-btn--small"
                        onclick="return confirm('¿Eliminar esta promoción permanentemente?')"
                      >
                        Eliminar
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</AdminLayout>
