---
interface Props {
  title?: string;
  description?: string;
}

import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/hero.css';
import '../styles/about.css';
import '../styles/menu.css';
import '../styles/promos.css';
import '../styles/location.css';
import '../styles/footer.css';

const {
  title = 'La Majada — Bar-restaurante',
  description = 'La Majada — bar-restaurante de barrio. Buena cocina, buena compañía y el ambiente de siempre.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" href="/Image/ImageAbout.jpg" type="image/jpeg" />
    <link rel="apple-touch-icon" href="/Image/ImageAbout.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script src="/js/header-scroll.js" defer></script>
    <script src="/js/map-embed.js" defer></script>
  </body>
</html>
