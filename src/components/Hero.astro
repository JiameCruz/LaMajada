---
import { resolveImageSrc } from '../lib/images';

const heroImage = resolveImageSrc('/Image/Hero Image.webp');
---
<section class="hero" aria-labelledby="hero-title">
  <div class="hero-media" aria-hidden="true">
    <img
      src={heroImage}
      alt="La Majada — ambiente del restaurante en Torreón"
      width="2400"
      height="1600"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-copy">
      <h1 id="hero-title" class="hero-title">Donde la amistad se sirve en mesa</h1>
      <p class="hero-lead">
        Bar-restaurante de barrio. Cocina honesta, copas bien servidas y el mismo trato de
        siempre — como cuando entras y ya te conocen.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="#reserva">Reserva mesa</a>
      </div>
    </div>
  </div>

  <a class="hero-scroll" href="#nosotros" aria-label="Desplázate para ver más">
    <span>Descubre</span>
    <svg
      class="hero-scroll-icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 5v14M5 12l7 7 7-7"></path>
    </svg>
  </a>
</section>
